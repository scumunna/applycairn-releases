{
  "mcpServers": {
    "applycairn-local": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.cjs"],
      "env": {
        "APPLYCAIRN_LOCAL_MODE": "1",
        "APPLYCAIRN_TEMPLATE_DIR": "${CLAUDE_PLUGIN_ROOT}/assets/workspace-template",
        "APPLYCAIRN_TENANT_ID": "workspace"
      }
    }
  }
}
